# Copy this file to .env.local and fill in values as needed.
# Everything here is OPTIONAL — the app runs with no config for a local demo.

# --- LLM (RM Chat) ---
# Free key from https://console.groq.com/keys. Without it, chat uses a fallback
# that only works on internal infra, so set this to enable real chat responses.
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile)
GROQ_MODEL=

# --- API gate (optional) ---
# If set, every /api/* request must send this token via either
#   x-api-token: <token>       or       Authorization: Bearer <token>
# Leave BLANK to disable the gate (default) so the demo works with no login.
API_GATE_TOKEN=

# --- Rate limiting (per IP, per minute) ---
# Defaults are applied if unset: general=100/min, chat=12/min.
RATE_LIMIT_GENERAL=100
RATE_LIMIT_CHAT=12

# --- Database (Prisma scaffold; not used by the app at runtime) ---
DATABASE_URL=file:./db/custom.db
