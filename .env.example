# Copy this file to .env.local and fill in values as needed.
# The app runs with NO config for a local demo (in-memory vectors, local
# embeddings, keyword-only answers). Add keys below to unlock full capabilities.

# ============================================================================
# LLM provider — priority: Gemini → Groq (used by RM Chat, RAG answers, and
# Document Intelligence vision). Set at least one to enable AI responses.
# Roles are split by capability:
#   - Text (chat, RAG answers): Groq gpt-oss-120b primary -> Gemini fallback.
#   - Vision (document OCR):     Gemini (Groq has no production vision model).
#   - Embeddings:                Gemini (Groq has no embeddings endpoint).
# Force the TEXT order with LLM_PROVIDER=groq|gemini (default: groq).
# ============================================================================
LLM_PROVIDER=

# --- Groq (primary text LLM) ---
# Free key from https://console.groq.com/keys
GROQ_API_KEY=
# default: openai/gpt-oss-120b (production; llama-3.3-70b-versatile is deprecating).
GROQ_MODEL=
# Groq vision is preview-only / deprecated — vision routes to Gemini regardless.
GROQ_VISION_MODEL=

# --- Gemini (embeddings + vision; text fallback) ---
# Free key from https://aistudio.google.com/apikey — REQUIRED (embeddings need it).
GEMINI_API_KEY=
# NOTE: default gemini-flash-lite-latest has free-tier quota. gemini-2.0-flash /
# 2.5-flash are billing-only ("limit: 0"). Bump once billing is enabled.
GEMINI_MODEL=                 # default: gemini-flash-lite-latest (fallback text + vision)
GEMINI_VISION_MODEL=          # default: same as GEMINI_MODEL
GEMINI_EMBED_MODEL=           # default: gemini-embedding-001 (requested at 768-dim)

# ============================================================================
# RAG embeddings — provider is auto-selected: Gemini if GEMINI_API_KEY is set,
# else local transformers.js (all-MiniLM-L6-v2, downloads ~90MB once to .cache/).
# ============================================================================
# Force one: gemini | local
EMBEDDINGS_PROVIDER=
# Local model override (only used when provider = local):
EMBEDDING_MODEL=              # default: Xenova/all-MiniLM-L6-v2

# ============================================================================
# Vector store — auto: Supabase if SUPABASE_URL + a key are set, else in-memory.
# For Vercel/production use Supabase (in-memory does NOT persist across
# serverless invocations). Run supabase/schema.sql once, then seed with
# `bun run scripts/seed-corpus.mjs`. NOTE: schema is vector(768) for Gemini
# embeddings — if using local embeddings change it to vector(384).
# ============================================================================
# Force one: supabase | memory
VECTOR_STORE=
SUPABASE_URL=
# Server-side only — prefer the service role key (bypasses RLS for upserts):
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ============================================================================
# API gate (optional) — if set, every /api/* request must send this token via
#   x-api-token: <token>   or   Authorization: Bearer <token>
# Leave BLANK to disable (default) so the demo works with no login.
# ============================================================================
API_GATE_TOKEN=

# --- Rate limiting (per IP, per minute). Defaults: general=100, chat/ai=12 ---
RATE_LIMIT_GENERAL=100
RATE_LIMIT_CHAT=12

# --- Prisma scaffold (not used by the app at runtime) ---
DATABASE_URL=file:./db/custom.db
